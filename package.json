{
  "name": "bike-calculator",
  "version": "0.0.3",
  "private": true,
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "node scripts/sync-version.mjs --increment",
    "prewatch": "npm run sync-version",
    "build": "rimraf dist && tsc -p tsconfig.json && shx mkdir -p dist && shx cp app.js version.js index.html styles.css dist/",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "shx": "^0.4.0",
    "typescript": "^5.0.0"
  }
}
